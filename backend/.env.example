# =============================================================================
# Gamora Bot API — variables de entorno
# Copiar a .env (local) o configurar en el host de staging/production
# =============================================================================

APP_ENV=local
NODE_ENV=development
PORT=3000

# Base de datos MySQL
DATABASE_URL="mysql://gamora:gamora_dev@localhost:3306/gamora_bot_dev"

# CORS — orígenes del frontend separados por coma
CORS_ORIGIN=http://localhost:4200

# -----------------------------------------------------------------------------
# Almacenamiento de evidencias (Fase 4 — extensible)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=uploads

# Futuro S3 / compatible
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=

# Futuro Cloudflare R2
# STORAGE_R2_ACCOUNT_ID=
# STORAGE_R2_BUCKET=

# Futuro Azure Blob
# STORAGE_AZURE_CONNECTION_STRING=

# -----------------------------------------------------------------------------
# IA opcional (Fase 3.1+)
# -----------------------------------------------------------------------------
AI_ENABLED=false
AI_PROVIDER=openai
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_MIN_CONFIDENCE=0.6

# Futuro: AI_PROVIDER=groq | ollama | mock

# -----------------------------------------------------------------------------
# WhatsApp Cloud API (Fase 4 — preparación; sin número real aún)
# -----------------------------------------------------------------------------
WHATSAPP_VERIFY_TOKEN=gamora-dev-verify-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_DEFAULT_WORKSPACE_SLUG=ferreteria-luisito
WHATSAPP_SEND_ENABLED=false
WHATSAPP_GRAPH_API_VERSION=v21.0
