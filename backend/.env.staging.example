# =============================================================================
# Gamora Bot API — STAGING (plantilla)
# Copiar a .env en el servidor staging. NO commitear .env.staging con secretos reales.
# =============================================================================

APP_ENV=staging
NODE_ENV=production

# Puerto interno del proceso Node (el reverse proxy termina TLS en 443)
PORT=3000

# MySQL staging — instancia SEPARADA del docker-compose local
DATABASE_URL="mysql://USER:PASSWORD@staging-mysql-host:3306/gamora_bot_staging"

# URL HTTPS exacta del frontend staging (sin barra final)
CORS_ORIGIN=https://staging.tu-dominio.com

# Evidencias — ruta absoluta persistente en el servidor
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=/var/gamora/uploads

# IA desactivada por defecto en staging
AI_ENABLED=false
AI_PROVIDER=openai
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# WhatsApp — preparación mock; NO activar envío real hasta fase Meta
WHATSAPP_VERIFY_TOKEN=cambiar-token-seguro-staging-min-32-chars
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_DEFAULT_WORKSPACE_SLUG=ferreteria-luisito
WHATSAPP_SEND_ENABLED=false
WHATSAPP_GRAPH_API_VERSION=v21.0
