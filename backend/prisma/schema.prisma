generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  coordinator
  assignee
  viewer
}

enum UserStatus {
  active
  suspended
  inactive
}

enum ContactStatus {
  active
  inactive
}

enum ChannelType {
  simulator
  whatsapp
  web
}

enum OptInStatus {
  pending
  active
  revoked
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageType {
  text
  audio
  image
  document
  system
}

enum MessageStatus {
  received
  pending_transcription
  transcription_failed
  ready
  processing
  processed
  failed
}

enum AssigneeRole {
  primary
  secondary
}

enum AssigneeStatus {
  pending
  accepted
  rejected
}

enum WorkspaceStatus {
  active
  inactive
}

model Workspace {
  id           String          @id @default(uuid()) @db.Char(36)
  name         String          @db.VarChar(255)
  slug         String          @unique @db.VarChar(100)
  status       WorkspaceStatus @default(active)
  settingsJson Json?           @map("settings_json")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  users               User[]
  contacts            Contact[]
  commitments         Commitment[]
  conversationThreads ConversationThread[]
  messages            Message[]
  evidenceFiles       EvidenceFile[]
  notifications       Notification[]

  @@map("workspaces")
}

model User {
  id           String     @id @default(uuid()) @db.Char(36)
  workspaceId  String     @map("workspace_id") @db.Char(36)
  email        String     @db.VarChar(255)
  passwordHash String?    @map("password_hash") @db.VarChar(255)
  displayName  String     @map("display_name") @db.VarChar(255)
  role         UserRole   @default(coordinator)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts      Contact[]
  notifications Notification[]

  @@unique([workspaceId, email])
  @@map("users")
}

model Notification {
  id                  String    @id @default(uuid()) @db.Char(36)
  workspaceId         String    @map("workspace_id") @db.Char(36)
  userId              String    @map("user_id") @db.Char(36)
  type                String    @db.VarChar(64)
  title               String    @db.VarChar(255)
  message             String    @db.Text
  relatedCommitmentId String?   @map("related_commitment_id") @db.Char(36)
  readAt              DateTime? @map("read_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([workspaceId, userId, createdAt])
  @@map("notifications")
}

model Contact {
  id          String        @id @default(uuid()) @db.Char(36)
  workspaceId String        @map("workspace_id") @db.Char(36)
  userId      String?       @map("user_id") @db.Char(36)
  displayName String        @map("display_name") @db.VarChar(255)
  phoneNumber String?       @map("phone_number") @db.VarChar(50)
  email       String?       @db.VarChar(255)
  position    String?       @db.VarChar(100)
  team        String?       @db.VarChar(100)
  status      ContactStatus @default(active)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at")

  workspace            Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                 User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  channelContacts      ChannelContact[]
  requestedCommitments Commitment[]        @relation("CommitmentRequester")
  assignees            CommitmentAssignee[]
  sentMessages         Message[]           @relation("MessageSender")

  @@map("contacts")
}

model ChannelContact {
  id           String      @id @default(uuid()) @db.Char(36)
  contactId    String      @map("contact_id") @db.Char(36)
  channel      ChannelType
  provider     String      @db.VarChar(50)
  externalId   String      @map("external_id") @db.VarChar(255)
  optInStatus  OptInStatus @default(active) @map("opt_in_status")
  optInAt      DateTime?   @map("opt_in_at")
  optOutAt     DateTime?   @map("opt_out_at")
  metadataJson Json?       @map("metadata_json")

  contact             Contact              @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversationThreads ConversationThread[]

  @@unique([channel, provider, externalId])
  @@map("channel_contacts")
}

model Commitment {
  id                   String    @id @default(uuid()) @db.Char(36)
  workspaceId          String    @map("workspace_id") @db.Char(36)
  folio                String    @db.VarChar(50)
  title                String    @db.VarChar(500)
  description          String?   @db.Text
  location             String?   @db.VarChar(255)
  status               String    @db.VarChar(50)
  requesterContactId   String?   @map("requester_contact_id") @db.Char(36)
  dueAt                DateTime? @map("due_at")
  expectedEvidence     String?   @map("expected_evidence") @db.Text
  conversationThreadId String?   @map("conversation_thread_id") @db.Char(36)
  originMessageId      String?   @unique @map("origin_message_id") @db.Char(36)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  closedAt             DateTime? @map("closed_at")

  workspace          Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requester          Contact?             @relation("CommitmentRequester", fields: [requesterContactId], references: [id], onDelete: SetNull)
  conversationThread ConversationThread?  @relation(fields: [conversationThreadId], references: [id], onDelete: SetNull)
  originMessage      Message?             @relation("CommitmentOriginMessage", fields: [originMessageId], references: [id], onDelete: SetNull)
  assignees          CommitmentAssignee[]
  events             CommitmentEvent[]
  messages           Message[]            @relation("CommitmentMessages")
  evidenceFiles      EvidenceFile[]

  @@unique([workspaceId, folio])
  @@index([workspaceId, status])
  @@map("commitments")
}

model CommitmentAssignee {
  id            String         @id @default(uuid()) @db.Char(36)
  commitmentId  String         @map("commitment_id") @db.Char(36)
  contactId     String         @map("contact_id") @db.Char(36)
  role          AssigneeRole   @default(primary)
  acceptedAt    DateTime?      @map("accepted_at")
  status        AssigneeStatus @default(pending)

  commitment Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
  contact    Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([commitmentId, contactId])
  @@map("commitment_assignees")
}

model CommitmentEvent {
  id               String   @id @default(uuid()) @db.Char(36)
  commitmentId     String   @map("commitment_id") @db.Char(36)
  eventType        String   @map("event_type") @db.VarChar(50)
  fromStatus       String?  @map("from_status") @db.VarChar(50)
  toStatus         String?  @map("to_status") @db.VarChar(50)
  actorContactId   String?  @map("actor_contact_id") @db.Char(36)
  actorUserId      String?  @map("actor_user_id") @db.Char(36)
  messageId        String?  @map("message_id") @db.Char(36)
  payloadJson      Json?    @map("payload_json")
  createdAt        DateTime @default(now()) @map("created_at")

  commitment Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)

  @@index([commitmentId, createdAt])
  @@map("commitment_events")
}

model ConversationThread {
  id                String      @id @default(uuid()) @db.Char(36)
  workspaceId       String      @map("workspace_id") @db.Char(36)
  channel           ChannelType
  channelContactId  String      @map("channel_contact_id") @db.Char(36)
  commitmentId      String?     @map("commitment_id") @db.Char(36)
  sessionState      String      @default("idle") @map("session_state") @db.VarChar(50)
  sessionContextJson Json?      @map("session_context_json")
  lastMessageAt     DateTime?   @map("last_message_at")
  createdAt         DateTime    @default(now()) @map("created_at")

  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channelContact ChannelContact @relation(fields: [channelContactId], references: [id], onDelete: Cascade)
  messages       Message[]
  commitments    Commitment[]

  @@index([workspaceId, channelContactId])
  @@map("conversation_threads")
}

model Message {
  id                String           @id @default(uuid()) @db.Char(36)
  threadId          String           @map("thread_id") @db.Char(36)
  workspaceId       String           @map("workspace_id") @db.Char(36)
  direction         MessageDirection
  channel           ChannelType
  provider          String           @db.VarChar(50)
  externalMessageId String?          @map("external_message_id") @db.VarChar(255)
  externalEventId   String?          @map("external_event_id") @db.VarChar(255)
  senderContactId   String?          @map("sender_contact_id") @db.Char(36)
  messageType       MessageType      @default(text) @map("message_type")
  textBody          String?          @map("text_body") @db.Text
  mediaId           String?          @map("media_id") @db.VarChar(255)
  mimeType          String?          @map("mime_type") @db.VarChar(100)
  status            MessageStatus    @default(received)
  commitmentId      String?          @map("commitment_id") @db.Char(36)
  rawPayloadJson    Json?            @map("raw_payload_json")
  createdAt         DateTime         @default(now()) @map("created_at")
  processedAt       DateTime?        @map("processed_at")

  thread            ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sender            Contact?           @relation("MessageSender", fields: [senderContactId], references: [id], onDelete: SetNull)
  commitment        Commitment?        @relation("CommitmentMessages", fields: [commitmentId], references: [id], onDelete: SetNull)
  originOfCommitment Commitment?       @relation("CommitmentOriginMessage")
  events            MessageEvent[]
  transcription     Transcription?
  aiExtractions     AiExtraction[]

  @@unique([channel, provider, externalMessageId])
  @@index([threadId, createdAt])
  @@map("messages")
}

model MessageEvent {
  id          String   @id @default(uuid()) @db.Char(36)
  messageId   String   @map("message_id") @db.Char(36)
  eventType   String   @map("event_type") @db.VarChar(50)
  payloadJson Json?    @map("payload_json")
  createdAt   DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
  @@map("message_events")
}

model EvidenceFile {
  id                  String   @id @default(uuid()) @db.Char(36)
  workspaceId         String   @map("workspace_id") @db.Char(36)
  commitmentId        String   @map("commitment_id") @db.Char(36)
  uploadedByContactId String?  @map("uploaded_by_contact_id") @db.Char(36)
  uploadedByUserId    String?  @map("uploaded_by_user_id") @db.Char(36)
  source              String   @default("web") @db.VarChar(50)
  mediaType           String   @map("media_type") @db.VarChar(50)
  originalFilename    String   @map("original_filename") @db.VarChar(500)
  mimeType            String   @map("mime_type") @db.VarChar(100)
  sizeBytes           Int      @map("size_bytes")
  storageProvider     String   @default("local") @map("storage_provider") @db.VarChar(50)
  storagePath         String   @map("storage_path") @db.VarChar(1000)
  createdAt           DateTime @default(now()) @map("created_at")

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  commitment Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)

  @@index([commitmentId, createdAt])
  @@map("evidence_files")
}

model Transcription {
  id             String    @id @default(uuid()) @db.Char(36)
  messageId      String    @unique @map("message_id") @db.Char(36)
  provider       String    @db.VarChar(50)
  transcriptText String?   @map("transcript_text") @db.Text
  status         String    @db.VarChar(50)
  errorMessage   String?   @map("error_message") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  completedAt    DateTime? @map("completed_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  aiExtractions AiExtraction[]

  @@map("transcriptions")
}

model AiExtraction {
  id                   String   @id @default(uuid()) @db.Char(36)
  messageId            String   @map("message_id") @db.Char(36)
  transcriptionId      String?  @map("transcription_id") @db.Char(36)
  inputText            String   @map("input_text") @db.Text
  detectedIntent       String?  @map("detected_intent") @db.VarChar(100)
  extractedJson        Json     @map("extracted_json")
  requiresConfirmation Boolean  @default(true) @map("requires_confirmation")
  status               String   @db.VarChar(50)
  model                String?  @db.VarChar(100)
  confidence           Float?
  createdAt            DateTime @default(now()) @map("created_at")

  message       Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  transcription Transcription? @relation(fields: [transcriptionId], references: [id], onDelete: SetNull)

  @@index([messageId, createdAt])
  @@map("ai_extractions")
}
